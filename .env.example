# Redis connection URL
# Local:              redis://localhost:6379
# With auth:          redis://:password@localhost:6379
# TLS (Valkey/AWS):   rediss://user:pass@hostname:6380
REDIS_URL=redis://localhost:6379

# BullMQ key prefix (must match the prefix used by your workers, default: {bullmq})
# BULLMQ_PREFIX={bullmq}

# Server config
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Optional basic auth for the UI
# BULLMQ_USERNAME=admin
# BULLMQ_PASSWORD=secret
