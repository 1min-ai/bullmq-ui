{
  "name": "@bullmq-studio/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "bullmq": "^5.34.8",
    "hono": "^4.7.11",
    "ioredis": "^5.4.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "bun-types": "^1.2.14",
    "typescript": "^5.7.3"
  }
}
