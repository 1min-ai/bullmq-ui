{
  "name": "bullmq-studio",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "bun run --filter @bullmq-studio/client dev",
    "dev:server": "bun run --filter @bullmq-studio/server dev",
    "build": "bun run --filter @bullmq-studio/server build && bun run --filter @bullmq-studio/client build",
    "start": "bun run --filter @bullmq-studio/server start",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
